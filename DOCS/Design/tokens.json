{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "LeadsReviver Design Tokens",
    "brand": "WW A.I Solutions",
    "version": "1.0.0",
    "description": "Design tokens for LeadsReviver — tailored to WW A.I Solutions brand. Supports LTR (English) and RTL (Hebrew)."
  },

  "color": {
    "brand": {
      "900": { "$value": "#0D1B5C", "$type": "color", "$description": "Deepest navy — hero backgrounds" },
      "800": { "$value": "#152070", "$type": "color", "$description": "Dark navy — section fills" },
      "700": { "$value": "#1A2B8A", "$type": "color", "$description": "Rich navy — primary dark surfaces" },
      "600": { "$value": "#1E3A8A", "$type": "color", "$description": "Brand navy — cards, banners" },
      "500": { "$value": "#2563EB", "$type": "color", "$description": "Primary blue — CTAs, active states" },
      "400": { "$value": "#3B82F6", "$type": "color", "$description": "Medium blue — hover states" },
      "300": { "$value": "#60A5FA", "$type": "color", "$description": "Sky blue — highlights, icons" },
      "200": { "$value": "#93C5FD", "$type": "color", "$description": "Light blue — tints, borders" },
      "100": { "$value": "#DBEAFE", "$type": "color", "$description": "Pale blue — chip backgrounds" },
      "50":  { "$value": "#EFF6FF", "$type": "color", "$description": "Near-white blue — page tints" }
    },
    "neutral": {
      "950": { "$value": "#0A0F1E", "$type": "color" },
      "900": { "$value": "#111827", "$type": "color" },
      "800": { "$value": "#1F2937", "$type": "color" },
      "700": { "$value": "#374151", "$type": "color" },
      "600": { "$value": "#4B5563", "$type": "color" },
      "500": { "$value": "#6B7280", "$type": "color" },
      "400": { "$value": "#9CA3AF", "$type": "color" },
      "300": { "$value": "#D1D5DB", "$type": "color" },
      "200": { "$value": "#E5E7EB", "$type": "color" },
      "100": { "$value": "#F3F4F6", "$type": "color" },
      "50":  { "$value": "#F9FAFB", "$type": "color" }
    },
    "semantic": {
      "primary":        { "$value": "{color.brand.500}", "$type": "color" },
      "primaryHover":   { "$value": "{color.brand.400}", "$type": "color" },
      "primaryActive":  { "$value": "{color.brand.600}", "$type": "color" },
      "primarySubtle":  { "$value": "{color.brand.100}", "$type": "color" },
      "heroBg":         { "$value": "{color.brand.800}", "$type": "color" },
      "surfaceBase":    { "$value": "#FFFFFF", "$type": "color" },
      "surfaceMuted":   { "$value": "{color.neutral.50}", "$type": "color" },
      "surfaceSubtle":  { "$value": "{color.neutral.100}", "$type": "color" },
      "textPrimary":    { "$value": "{color.neutral.900}", "$type": "color" },
      "textSecondary":  { "$value": "{color.neutral.600}", "$type": "color" },
      "textMuted":      { "$value": "{color.neutral.400}", "$type": "color" },
      "textInverse":    { "$value": "#FFFFFF", "$type": "color" },
      "textBrand":      { "$value": "{color.brand.500}", "$type": "color" },
      "borderDefault":  { "$value": "{color.neutral.200}", "$type": "color" },
      "borderStrong":   { "$value": "{color.neutral.300}", "$type": "color" }
    },
    "status": {
      "success": { "$value": "#10B981", "$type": "color" },
      "successBg": { "$value": "#D1FAE5", "$type": "color" },
      "warning": { "$value": "#F59E0B", "$type": "color" },
      "warningBg": { "$value": "#FEF3C7", "$type": "color" },
      "error":   { "$value": "#EF4444", "$type": "color" },
      "errorBg": { "$value": "#FEE2E2", "$type": "color" },
      "info":    { "$value": "#06B6D4", "$type": "color" },
      "infoBg":  { "$value": "#CFFAFE", "$type": "color" }
    }
  },

  "typography": {
    "fontFamily": {
      "display": { "$value": "'Syne', 'Heebo', sans-serif", "$type": "fontFamily", "$description": "Headings and hero text — LTR" },
      "body":    { "$value": "'Plus Jakarta Sans', 'Heebo', sans-serif", "$type": "fontFamily", "$description": "Body copy and UI — LTR" },
      "mono":    { "$value": "'JetBrains Mono', 'Fira Code', monospace", "$type": "fontFamily" },
      "hebrew":  { "$value": "'Heebo', 'Assistant', sans-serif", "$type": "fontFamily", "$description": "Hebrew primary font (RTL)" }
    },
    "fontSize": {
      "xs":   { "$value": "0.75rem",  "$type": "dimension", "$description": "12px" },
      "sm":   { "$value": "0.875rem", "$type": "dimension", "$description": "14px" },
      "base": { "$value": "1rem",     "$type": "dimension", "$description": "16px" },
      "md":   { "$value": "1.125rem", "$type": "dimension", "$description": "18px" },
      "lg":   { "$value": "1.25rem",  "$type": "dimension", "$description": "20px" },
      "xl":   { "$value": "1.5rem",   "$type": "dimension", "$description": "24px" },
      "2xl":  { "$value": "1.875rem", "$type": "dimension", "$description": "30px" },
      "3xl":  { "$value": "2.25rem",  "$type": "dimension", "$description": "36px" },
      "4xl":  { "$value": "3rem",     "$type": "dimension", "$description": "48px" },
      "5xl":  { "$value": "3.75rem",  "$type": "dimension", "$description": "60px" },
      "6xl":  { "$value": "4.5rem",   "$type": "dimension", "$description": "72px" }
    },
    "fontWeight": {
      "light":     { "$value": 300, "$type": "fontWeight" },
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "medium":    { "$value": 500, "$type": "fontWeight" },
      "semibold":  { "$value": 600, "$type": "fontWeight" },
      "bold":      { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight" }
    },
    "lineHeight": {
      "none":    { "$value": 1,    "$type": "number" },
      "tight":   { "$value": 1.2,  "$type": "number" },
      "snug":    { "$value": 1.35, "$type": "number" },
      "normal":  { "$value": 1.5,  "$type": "number" },
      "relaxed": { "$value": 1.6,  "$type": "number" },
      "loose":   { "$value": 1.8,  "$type": "number" }
    },
    "letterSpacing": {
      "tighter": { "$value": "-0.04em", "$type": "dimension" },
      "tight":   { "$value": "-0.02em", "$type": "dimension" },
      "normal":  { "$value": "0em",     "$type": "dimension" },
      "wide":    { "$value": "0.04em",  "$type": "dimension" },
      "wider":   { "$value": "0.08em",  "$type": "dimension" },
      "widest":  { "$value": "0.16em",  "$type": "dimension" }
    }
  },

  "spacing": {
    "0":    { "$value": "0",        "$type": "dimension" },
    "px":   { "$value": "1px",      "$type": "dimension" },
    "1":    { "$value": "0.25rem",  "$type": "dimension", "$description": "4px" },
    "2":    { "$value": "0.5rem",   "$type": "dimension", "$description": "8px" },
    "3":    { "$value": "0.75rem",  "$type": "dimension", "$description": "12px" },
    "4":    { "$value": "1rem",     "$type": "dimension", "$description": "16px" },
    "5":    { "$value": "1.25rem",  "$type": "dimension", "$description": "20px" },
    "6":    { "$value": "1.5rem",   "$type": "dimension", "$description": "24px" },
    "8":    { "$value": "2rem",     "$type": "dimension", "$description": "32px" },
    "10":   { "$value": "2.5rem",   "$type": "dimension", "$description": "40px" },
    "12":   { "$value": "3rem",     "$type": "dimension", "$description": "48px" },
    "16":   { "$value": "4rem",     "$type": "dimension", "$description": "64px" },
    "20":   { "$value": "5rem",     "$type": "dimension", "$description": "80px" },
    "24":   { "$value": "6rem",     "$type": "dimension", "$description": "96px" },
    "32":   { "$value": "8rem",     "$type": "dimension", "$description": "128px" }
  },

  "borderRadius": {
    "none":  { "$value": "0",       "$type": "dimension" },
    "sm":    { "$value": "0.25rem", "$type": "dimension", "$description": "4px" },
    "md":    { "$value": "0.5rem",  "$type": "dimension", "$description": "8px" },
    "lg":    { "$value": "0.75rem", "$type": "dimension", "$description": "12px" },
    "xl":    { "$value": "1rem",    "$type": "dimension", "$description": "16px" },
    "2xl":   { "$value": "1.5rem",  "$type": "dimension", "$description": "24px" },
    "3xl":   { "$value": "2rem",    "$type": "dimension", "$description": "32px" },
    "full":  { "$value": "9999px",  "$type": "dimension" }
  },

  "shadow": {
    "xs":          { "$value": "0 1px 2px rgba(0,0,0,0.05)", "$type": "shadow" },
    "sm":          { "$value": "0 1px 3px rgba(0,0,0,0.10), 0 1px 2px rgba(0,0,0,0.06)", "$type": "shadow" },
    "md":          { "$value": "0 4px 6px rgba(0,0,0,0.07), 0 2px 4px rgba(0,0,0,0.06)", "$type": "shadow" },
    "lg":          { "$value": "0 10px 15px rgba(0,0,0,0.10), 0 4px 6px rgba(0,0,0,0.05)", "$type": "shadow" },
    "xl":          { "$value": "0 20px 25px rgba(0,0,0,0.10), 0 10px 10px rgba(0,0,0,0.04)", "$type": "shadow" },
    "2xl":         { "$value": "0 25px 50px rgba(0,0,0,0.25)", "$type": "shadow" },
    "brand":       { "$value": "0 4px 14px rgba(37,99,235,0.35)", "$type": "shadow" },
    "brandHover":  { "$value": "0 8px 20px rgba(37,99,235,0.45)", "$type": "shadow" },
    "card":        { "$value": "0 2px 8px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04)", "$type": "shadow" },
    "cardHover":   { "$value": "0 8px 24px rgba(0,0,0,0.10), 0 4px 8px rgba(0,0,0,0.06)", "$type": "shadow" },
    "inputFocus":  { "$value": "0 0 0 3px rgba(37,99,235,0.20)", "$type": "shadow" }
  },

  "animation": {
    "duration": {
      "instant":  { "$value": "50ms",  "$type": "duration" },
      "fast":     { "$value": "100ms", "$type": "duration" },
      "normal":   { "$value": "200ms", "$type": "duration" },
      "slow":     { "$value": "300ms", "$type": "duration" },
      "slower":   { "$value": "500ms", "$type": "duration" },
      "slowest":  { "$value": "700ms", "$type": "duration" }
    },
    "easing": {
      "linear":  { "$value": "linear", "$type": "cubicBezier" },
      "easeIn":  { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
      "easeOut": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
      "easeInOut": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "spring":  { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    }
  },

  "zIndex": {
    "below":    { "$value": -1,  "$type": "number" },
    "base":     { "$value": 0,   "$type": "number" },
    "raised":   { "$value": 10,  "$type": "number" },
    "dropdown": { "$value": 100, "$type": "number" },
    "sticky":   { "$value": 200, "$type": "number" },
    "overlay":  { "$value": 300, "$type": "number" },
    "modal":    { "$value": 400, "$type": "number" },
    "toast":    { "$value": 500, "$type": "number" },
    "tooltip":  { "$value": 600, "$type": "number" }
  },

  "rtl": {
    "$description": "RTL/Hebrew-specific token overrides. Apply when dir=rtl is set.",
    "fontFamily": {
      "display": { "$value": "'Heebo', sans-serif", "$type": "fontFamily" },
      "body":    { "$value": "'Heebo', sans-serif", "$type": "fontFamily" }
    },
    "lineHeight": {
      "normal":  { "$value": 1.6,  "$type": "number", "$description": "Slightly looser for Hebrew readability" },
      "relaxed": { "$value": 1.75, "$type": "number" }
    }
  }
}
